# Piston API Configuration
# For local setup, use: http://localhost:2000/api/v2
PISTON_API_URL=http://localhost:2000/api/v2

# Zoom API Configuration (Optional - for Group Discussion feature)
# Get credentials from Zoom App Marketplace: https://marketplace.zoom.us/
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# VAPI AI Configuration (Required for AI features)
# Get your key from https://vapi.ai/
VAPI_API_KEY=your_vapi_key_here
VAPI_GD_ASSISTANT_ID=your_vapi_gd_assistant_id

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
CLIENT_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
